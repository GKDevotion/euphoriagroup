RewriteRule ^tours-travels tours-travels.php?slug=$1 [L,QSA]
RewriteRule ^wealth-asset-solution wealth-asset-solution.php?slug=$1 [L,QSA]
RewriteRule ^visa-assistance visa-assistance.php?slug=$1 [L,QSA]
